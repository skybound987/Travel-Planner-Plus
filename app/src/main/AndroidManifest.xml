<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" >
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TravelPlannerPlus">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.DestinationList"
            android:exported="false"
            android:label="@string/destination_list_header"
            android:parentActivityName=".ui.MainActivity" />
        <activity
            android:name=".ui.DestinationDetails"
            android:exported="false"
            android:label="@string/destination_details_header"
            android:parentActivityName=".ui.DestinationList" />
        <activity
            android:name=".ui.DestinationActivityDetails"
            android:exported="false"
            android:label="@string/activity_details_header"
            android:parentActivityName=".ui.DestinationDetails" />
        <receiver
            android:name=".ui.AlertReceiver"
            android:exported="false" />
    </application>
</manifest>